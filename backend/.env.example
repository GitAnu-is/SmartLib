# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/smartlib
JWT_SECRET=change_me

# SMTP (for overdue reminder emails)
# For Gmail, use an App Password and set SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="SmartLib <no-reply@smartlib.local>"
